<div style="background: #2c3e50; padding: 15px; color: white;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center;">
    <h2 style="margin: 0;">
      <%= link_to "🏠 Winnipeg Home Essentials", root_path, style: "color: white; text-decoration: none;" %>
    </h2>
    <div>
      <%= link_to "Products", products_path, style: "color: white; text-decoration: none; margin-right: 20px;" %>
      <%= link_to "About", "/about", style: "color: white; text-decoration: none; margin-right: 20px;" %>
      <%= link_to "Contact", "/contact", style: "color: white; text-decoration: none; margin-right: 20px;" %>
      <% 
        cart_count = 0
        if session[:cart].present? && session[:cart].is_a?(Hash)
          session[:cart].each do |key, value|
            cart_count += value.to_i if value.is_a?(Numeric)
          end
        end
      %>
      <%= link_to "🛒 Cart (#{cart_count})", cart_path, style: "color: white; text-decoration: none; margin-right: 20px;" %>
      <%= link_to "Admin", "/admin", style: "color: #27ae60; text-decoration: none;" %>
    </div>
  </div>
</div>
