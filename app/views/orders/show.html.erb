<h1>Order #<%= @order.id %></h1>

<div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
  <p><strong>Order Date:</strong> <%= @order.created_at.strftime("%B %d, %Y at %I:%M %p") %></p>
  <p><strong>Status:</strong> 
    <span style="background: <%= @order.status == 'paid' ? '#27ae60' : '#f39c12' %>; color: white; padding: 4px 8px; border-radius: 4px;">
      <%= @order.status.capitalize %>
    </span>
  </p>
  <p><strong>Shipping Address:</strong><br>
    <%= @order.user.address %><br>
    <%= @order.user.city %>, <%= @order.province&.name %> <%= @order.user.postal_code %>
  </p>
</div>

<h2>Order Items</h2>
<table style="width: 100%; border-collapse: collapse;">
  <thead>
    <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
      <th style="padding: 12px; text-align: left;">Product</th>
      <th style="padding: 12px; text-align: center;">Quantity</th>
      <th style="padding: 12px; text-align: right;">Unit Price</th>
      <th style="padding: 12px; text-align: right;">Total</th>
      </tr>
  </thead>
  <tbody>
    <% @order.order_items.each do |item| %>
      <tr style="border-bottom: 1px solid #dee2e6;">
        <td style="padding: 12px;"><%= item.product.name %></td>
        <td style="padding: 12px; text-align: center;"><%= item.quantity %></td>
        <td style="padding: 12px; text-align: right;">$<%= item.unit_price %></td>
        <td style="padding: 12px; text-align: right;">$<%= item.total_price %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr style="border-top: 2px solid #dee2e6;">
      <td colspan="3" style="padding: 12px; text-align: right;"><strong>Subtotal:</strong></td>
      <td style="padding: 12px; text-align: right;">$<%= @order.subtotal %></td>
    </tr>
    <tr>
      <td colspan="3" style="padding: 12px; text-align: right;"><strong>Tax:</strong></td>
      <td style="padding: 12px; text-align: right;">$<%= @order.tax %></td>
    </tr>
    <tr style="background: #f8f9fa;">
      <td colspan="3" style="padding: 12px; text-align: right; font-size: 18px;"><strong>Total:</strong></td>
      <td style="padding: 12px; text-align: right; font-size: 24px; color: #27ae60; font-weight: bold;">$<%= @order.total %></td>
    </tr>
  </tfoot>
</table>

<div style="margin-top: 20px;">
  <%= link_to "← Back to My Orders", orders_path, style: "color: #3498db;" %>
</div>
