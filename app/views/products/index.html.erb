<div class="products-page">
  <h1>Our Products</h1>

  <!-- Filter Buttons -->
  <div class="filter-buttons">
    <%= link_to "All Products", products_path(filter: nil), class: "filter-btn #{'active' if params[:filter].nil?}" %>
    <%= link_to "🆕 New Products", products_path(filter: 'new'), class: "filter-btn new #{'active' if params[:filter] == 'new'}" %>
    <%= link_to "🔄 Recently Updated", products_path(filter: 'recently_updated'), class: "filter-btn updated #{'active' if params[:filter] == 'recently_updated'}" %>
    <%= link_to "🏷️ On Sale", products_path(filter: 'on_sale'), class: "filter-btn sale #{'active' if params[:filter] == 'on_sale'}" %>
  </div>

  <!-- Search Form -->
  <div class="search-form">
    <%= search_form_for @q, url: products_path, method: :get do |f| %>
      <%= hidden_field_tag :filter, params[:filter] %>
      <%= hidden_field_tag :page, params[:page] %>
      <div>
        <div class="search-input">
          <%= f.search_field :name_or_description_cont, 
              placeholder: "Search by product name or description...", 
              value: params[:q]&.dig(:name_or_description_cont) %>
        </div>
        <div class="category-select">
          <%= f.select :category_id_eq, 
              options_from_collection_for_select(Category.all, :id, :name, params[:q]&.dig(:category_id_eq)), 
              { include_blank: "All Categories" } %>
        </div>
        <div class="search-actions">
          <%= f.submit "Search" %>
          <%= link_to "Clear", products_path(filter: params[:filter]), class: "clear-link" %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Products Grid -->
  <div class="products-grid">
    <% if @products.any? %>
      <% @products.each do |product| %>
        <div class="product-card">
          <div class="badges">
            <% if product.on_sale? %>
              <div class="badge sale-badge">🔥 <%= product.discount_percentage %>% OFF</div>
            <% end %>
            <% if product.is_new? && !product.on_sale? %>
              <div class="badge new-badge">🆕 NEW</div>
            <% end %>
            <% if product.recently_updated? && !product.is_new? && !product.on_sale? %>
              <div class="badge updated-badge">🔄 UPDATED</div>
            <% end %>
          </div>
          
          <h3><%= link_to product.name, product_path(product) %></h3>
          <p class="product-description"><%= truncate(product.description, length: 100) %></p>
          
          <div class="price">
            <% if product.on_sale? %>
              <p class="original-price">Was: $<%= product.price %></p>
              <p class="sale-price">$<%= product.sale_price %></p>
              <p class="save-amount">Save $<%= (product.price - product.sale_price).round(2) %>!</p>
            <% else %>
              <p class="regular-price">$<%= product.price %></p>
            <% end %>
          </div>
          
          <p class="stock"><%= pluralize(product.stock_quantity, 'unit') %> available</p>
          
          <div class="add-to-cart">
            <% if product.stock_quantity > 0 %>
              <%= link_to "Add to Cart", test_add_to_cart_path(product.id), class: product.on_sale? ? "sale-button" : "" %>
            <% else %>
              <button disabled>Out of Stock</button>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="no-products">No products found.</p>
    <% end %>
  </div>

  <!-- Pagination -->
  <div class="pagination">
    <%= paginate @products %>
  </div>
</div>
